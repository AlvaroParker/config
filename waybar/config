{
  "layer": "top",
  "height": 35,
  "margin-top": 10,
  "margin-left": 10,
  "margin-bottom": 0,
  "margin-right": 10,
  "spacing": 0,

  "modules-left": [
    "custom/launcher",
    "custom/separator",
    "cpu",
    "memory",
    "custom/separator",
    "custom/window-name",
    "custom/pacman-update-icon",
    "custom/pacman-update",
    "tray"
  ],

  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    "battery",
    "backlight",
    "pulseaudio",
    "custom/right-arr",
    "network",
    "custom/clock-icon",
    "clock"
  ],

  "hyprland/workspaces": {
    "all-outputs": true,
    "active-only": false,
    "on-click": "activate",
    "format": "{icon}",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "format-icons": {
      "1": "пДМ",
      "2": "пДМ",
      "3": "пДМ",
      "4": "пДМ",
      "5": "пДМ",
      "6": "пДМ",
      "urgent": "пБ™",
      "active": "пЖТ",
      "default": "пДС"
    }
  },

  "tray": {
    "icon-size": 20,
    "spacing": 8
  },

  "custom/clock-icon": {
    "format": "оїЙ"
  },

  "clock": {
    "format": "<b>{:%I:%M %p}</b>",
    "format-alt": "<b>{:%a.%d,%b}</b>",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "cpu": {
    "interval": 10,
    "format": "ої† {usage}%",
    "max-length": 10,
    "tooltip": false
  },
  "memory": {
    "interval": 30,
    "format": "пДµ {used}GiB",
    "format-alt": "пС≤ {used:0.1f}G",
    "max-length": 10
  },
  "backlight": {
    "device": "amdgpu_bl1",
    "format": "{icon} {percent}",
    "tooltip": false,
    "format-icons": ["оІХ", "оІЦ", "оІФ"]
  },
  "network": {
    "format-wifi": "оІ† {essid}",
    "on-click": "iwgtk",
    "format-ethernet": "о∞Я wired",
    "tooltip": false,
    "format-disconnected": ""
  },

  "pulseaudio": {
    "format": "{icon} <b>{volume}</b>",
    "format-bluetooth": "пА• о§•",
    "format-bluetooth-muted": "пЪ© пКФ",
    "tooltip": false,
    "format-muted": "о§≤",
    "format-icons": {
      "default": ["о§±", "о§∞", "о§≥"]
    },
    "on-click": "pavucontrol"
  },
  "battery": {
    "bat": "BAT1",
    "interval": 30,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "оіУ {icon} {capacity}%",
    "format-icons": ["пЙГ ", "пЙВ ", "пЙБ ", "пЙА "],
    "max-length": 25,
    "tooltip": false
  },
  "custom/right-arr": {
    "format": " пГЪ "
  },
  "custom/launcher": {
    "format": "пМГ"
  },
  "custom/separator": {
    "format": " "
  },
  "custom/window-name": {
    "format": "<b>{}</b>",
    "interval": 1,
    "exec": "hyprctl activewindow | grep class | awk '{print $2}' | sed 's/\\([[:alpha:]]\\)/\\U\\1/'"
  },

  "custom-pacman-update-icon-background": {
    "format": ""
  },
  "custom/pacman-update-icon": {
    "format": "оЇ•"
  },
  "custom/pacman-update": {
    "format": " {}",
    "interval": 3600,
    "exec": "$HOME/.config/waybar/scripts/checkupdates | wc -l",
    "signal": 8
  },
  "custom/window-icon": {},
  "custom/wrap-left": {
    "format": "<b>[</b>"
  },

  "custom/wrap-right": {
    "format": "<b>]</b>"
  }
}
