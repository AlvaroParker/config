{
  "layer": "top",
  "position": "top",
  "height": 35,
  "margin-top": 10,
  "margin-left": 10,
  "margin-bottom": 0,
  "margin-right": 10,
  "spacing": 0,

  "modules-left": [
    "custom/launcher",
    "custom/separator",
    "cpu",
    "memory",
    "custom/separator",
    "custom/window-name",
    "custom/pacman-update-icon",
    "custom/pacman-update",
    "tray"
  ],

  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    "battery",
    "backlight",
    "custom/wl-gammarelay-temperature",
    "pulseaudio",
    "custom/right-arr",
    "network",
    "custom/clock-icon",
    "clock"
  ],
  "custom/wl-gammarelay-temperature": {
