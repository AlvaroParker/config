#! /bin/bash
create_symlinks() {
    local source_directory="$1"
    local target_directory="$2"

    # Ensure the target directory exists
    mkdir -p "$target_directory"

    # Loop through each file in the source directory
    for file in "$source_directory"/*; do
        if [ -f "$file" ]; then
            ln -s "$file" "$target_directory"
        fi
    done
}
current_dir=$(pwd)

packages=("rustup" "base-devel" "hyprland" "xdg-desktop-portal-hyprland" "alacritty" "nautilus" "rofi" "flatpak" "gammastep" "light" "grim" "wl-clipboard" "slurp" "dunst" "waybar" "blueman" "btop" "fish" "neovim" "zathura" "lsd")
# Filter out already installed packages
to_install=()
for pkg in "${packages[@]}"; do
    if ! pacman -Qq $pkg &>/dev/null; then
        to_install+=("$pkg")
    fi
done
if (( ${#to_install[@]} > 0 )); then
    sudo pacman -S "${to_install[@]}"
else
    echo "Dependencies already installed."
fi

# Install paru
if ! pacman -Qq paru &>/dev/null; then
    mkdir -p ~/aur
    cd ~/aur
    git clone https://aur.archlinux.org/paru-bin.git
    cd paru-bin
    makepkg -si --noconfirm
else
    echo "Paru already installed."
fi

# Install AUR packages
aur_packages=("hyprpicker-git" "nerd-fonts-meta" "rate-mirrors" "swayosd-git" "visual-studio-code-bin")
aur_to_install=()

for pkg in "${aur_packages[@]}"; do
    if ! pacman -Qq $pkg &>/dev/null; then
        aur_to_install+=("$pkg")
    fi
done
if (( ${#aur_to_install[@]} > 0 )); then
    paru -S "${aur_to_install[@]}"
else
    echo "AUR dependencies already installed."
fi

cd $current_dir
# Install AstroNvim
rm rf ~/.config/nvim ~/.local/share/nvim ~/.local/state/nvim ~/.cache/nvim
git clone --depth 1 https://github.com/AstroNvim/AstroNvim ~/.config/nvim
mkdir -p ~/.config/nvim/lua/user
ln -s ./nvim/lua/user/init.lua ~/.config/nvim/lua/user/init.lua


# Install tmux plugin manager
rm -rf ~/.tmux.conf
ln ./tmux.conf ~/.tmux.conf
git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm

# Install alacritty config
rm -rf ~/.config/alacritty
ln -s ./alacritty ~/.config/alacritty

# Install dunst config
rm -rf ~/.config/dunst
ln -s ./dunst ~/.config/dunst

# Install hyprland config
rm -rf ~/.config/hypr
ln -s ./hypr ~/.config/hypr

# Install neofetch config
rm -rf ~/.config/neofetch
ln -s ./neofetch ~/.config/neofetch

# Install rofi config
rm -rf ~/.config/rofi
ln -s ./rofi ~/.config/rofi

# Install waybar config
rm -rf ~/.config/waybar
ln -s ./waybar ~/.config/waybar

# Install zathura config
rm -rf ~/.config/zathura
ln -s ./zathura ~/.config/zathura

unzip ./icomoon.zip
mkdir -p ~/.local/share/fonts
cp ./icomoon/fonts ~/.local/share/fonts

# Install code config
mkdir -p ~/.config/Code/User
rm -rf ~/.config/Code/User/settings.json ~/.config/Code/User/keybinds.json
ln -s ./Code/User/keybinds.json ~/.config/Code/User/keybinds.json
ln -s ./Code/User/settings.json ~/.config/Code/User/settings.json

# Install bin
create_symlinks "./bin" "~/.local/bin"


~/.local/bin/set_wallpaper ~/.config/hypr/wallpapers/wallpaper.png
# Install omf
rm -rf ~/.config/fish
create_symlinks "./fish" "~/.config/fish"
ln -s ./omf ~/.config/omf
curl https://raw.githubusercontent.com/oh-my-fish/oh-my-fish/master/bin/install | fish
